---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GameCard from '../../../components/GameCard.astro';
import AdSlot from '../../../components/ads/AdSlot.astro';
import { getGamesByCategory, L } from '../../../lib/games';
import { CATEGORIES, CATEGORY_ICON, type CategoryId } from '../../../lib/categories';
import { locales, localizePath, useTranslations, defaultLocale, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return locales.flatMap((locale) =>
    CATEGORIES.map((category) => ({ params: { locale, category } })),
  );
}

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const category = Astro.params.category as CategoryId;
const t = useTranslations(locale);
const games = await getGamesByCategory(category);
const site = (Astro.site ?? new URL('https://jellyzap.com')).href;
const name = t(`categories.${category}.name`);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('nav.home'), item: new URL(localizePath(locale, '/'), site).href },
      { '@type': 'ListItem', position: 2, name: t('nav.games'), item: new URL(localizePath(locale, '/games'), site).href },
      { '@type': 'ListItem', position: 3, name },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: t('category.titleTemplate', { name }),
    itemListElement: games.map((g, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(localizePath(locale, `/g/${g.data.slug}`), site).href,
      name: L(g.data.title, locale),
    })),
  },
];
---

<BaseLayout
  locale={locale}
  title={t('seo.categoryTitleTemplate', { name })}
  description={t('category.intro', { name })}
  path={`/c/${category}`}
  jsonLd={jsonLd}
>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={localizePath(locale, '/')}>{t('nav.home')}</a>
      <span>/</span>
      <a href={localizePath(locale, '/games')}>{t('nav.games')}</a>
      <span>/</span>
      <span>{name}</span>
    </nav>

    <header class="page-head">
      <h1><span aria-hidden="true">{CATEGORY_ICON[category]}</span> {t('category.titleTemplate', { name })}</h1>
      <p>{t(`categories.${category}.desc`)}</p>
    </header>

    <AdSlot placement="banner" locale={locale} />

    <div class="grid">
      {games.map((g) => <GameCard game={g} locale={locale} />)}
    </div>
  </div>
</BaseLayout>

<style>
  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.5rem 1rem 2rem;
  }
  .crumbs {
    display: flex;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-ink-dim, #b9a7e0);
    margin-bottom: 0.8rem;
  }
  .crumbs a:hover {
    color: var(--color-bubble, #ff4d8d);
  }
  .page-head h1 {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    margin: 0;
  }
  .page-head p {
    color: var(--color-ink-dim, #b9a7e0);
    margin: 0.3rem 0 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
</style>
