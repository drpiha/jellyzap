---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeStaticPaths, useTranslations, getList, defaultLocale, type Locale } from '../../i18n';

export function getStaticPaths() {
  return localeStaticPaths();
}

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const t = useTranslations(locale);
const body = getList(locale, 'terms.body');
---

<BaseLayout
  locale={locale}
  title={`${t('terms.title')} | Jellyzap`}
  description={t('terms.title')}
  path="/terms"
>
  <div class="prose">
    <h1>{t('terms.title')}</h1>
    {body.map((p) => <p>{p}</p>)}
  </div>
</BaseLayout>

<style>
  .prose {
    max-width: 70ch;
    margin: 0 auto;
    padding: 2.5rem 1rem;
  }
  .prose h1 {
    font-size: 2rem;
  }
  .prose p {
    line-height: 1.7;
    color: var(--color-ink-dim, #b9a7e0);
    margin: 1rem 0;
  }
</style>
