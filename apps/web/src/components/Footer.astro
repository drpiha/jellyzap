---
import { localizePath, useTranslations, type Locale } from '../i18n';
import { CATEGORIES } from '../lib/categories';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <div class="col brandcol">
      <span class="name">Jelly<span class="zap">zap</span></span>
      <p>{t('footer.tagline')}</p>
    </div>

    <div class="col">
      <h4>{t('footer.explore')}</h4>
      <ul>
        <li><a href={localizePath(locale, '/')}>{t('nav.home')}</a></li>
        <li><a href={localizePath(locale, '/games')}>{t('nav.games')}</a></li>
        {
          CATEGORIES.map((c) => (
            <li>
              <a href={localizePath(locale, `/c/${c}`)}>{t(`categories.${c}.name`)}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="col">
      <h4>{t('footer.legal')}</h4>
      <ul>
        <li><a href={localizePath(locale, '/about')}>{t('footer.about')}</a></li>
        <li><a href={localizePath(locale, '/privacy')}>{t('footer.privacy')}</a></li>
        <li><a href={localizePath(locale, '/terms')}>{t('footer.terms')}</a></li>
        <li>
          <button type="button" class="linklike" data-jz-consent-open>{t('consent.customize')}</button>
        </li>
      </ul>
    </div>
  </div>

  <div class="legal">
    <p>{t('footer.disclaimer')}</p>
    <p>© {year} Jellyzap. {t('footer.rights')}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(8, 4, 20, 0.4);
  }
  .inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem 1rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 1.5rem;
  }
  .name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
  }
  .zap {
    color: var(--color-bubble, #ff4d8d);
  }
  .brandcol p {
    color: var(--color-ink-dim, #b9a7e0);
    max-width: 28ch;
  }
  .col h4 {
    margin: 0 0 0.6rem;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-dim, #b9a7e0);
  }
  .col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }
  .col a,
  .linklike {
    color: var(--color-ink, #f4ecff);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .col a:hover,
  .linklike:hover {
    color: var(--color-bubble, #ff4d8d);
  }
  .linklike {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }
  .legal {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-ink-dim, #b9a7e0);
    font-size: 0.8rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .inner {
      grid-template-columns: 1fr 1fr;
    }
    .brandcol {
      grid-column: 1 / -1;
    }
  }
</style>
