# Copy to .env and fill in real values for production.

# Canonical site URL (used for SEO, sitemap, OG, structured data)
PUBLIC_SITE_URL=https://jellyzap.com

# --- Monetization (Google AdSense) ---
# Set to "true" once you have a real publisher id + slots.
PUBLIC_ADS_ENABLED=false
PUBLIC_AD_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_AD_SLOT_BANNER=
PUBLIC_AD_SLOT_INCONTENT=
PUBLIC_AD_SLOT_SIDEBAR=
PUBLIC_AD_SLOT_INTERSTITIAL=
PUBLIC_AD_SLOT_REWARDED=

# --- Analytics (Google Analytics 4) ---
PUBLIC_GA4_ID=
